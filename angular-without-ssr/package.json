{
  "name": "angular-without-ssr",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "prebuild:prod": "cp src/environments/environments.default.ts src/environments/environments.ts",
    "build:prod": "ng build --configuration production",
    "build-cloudflare": "node inject-env.js && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --ext .ts,.html",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.3",
