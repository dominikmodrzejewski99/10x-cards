    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.12.0",
    "angular-eslint": "^21.3.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "jasmine-core": "~5.6.0",
